{
  "name": "alat-dependency-graph",
  "displayName": "Alat / Dependency Graph",
  "description": "Visualize your codebase as an interactive dependency graph. Explore call graphs, class diagrams, and code structure for any language.",
  "keywords": [
    "dependency graph",
    "code visualization",
    "diagram",
    "call graph",
    "code map",
    "uml",
    "class diagram",
    "code navigation",
    "architecture",
    "graph",
    "visualization",
    "code analysis"
  ],
  "version": "0.4.0",
  "publisher": "gsuleimanov",
  "license": "Apache-2.0",
  "icon": "images/codenav-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/GSuleimanov/vscode-extension--codenav.git"
  },
  "bugs": {
    "url": "https://github.com/GSuleimanov/vscode-extension--codenav/issues"
  },
  "homepage": "https://github.com/GSuleimanov/vscode-extension--codenav#readme",
  "engines": {
    "vscode": "^1.64.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "alat.openDependencyGraph",
        "title": "Open Dependency Graph",
        "category": "Alat",
        "icon": "$(circuit-board)"
      }
    ],
    "configuration": {
      "title": "Alat / Dependency Graph",
      "properties": {
        "alat.nodeSize": {
          "type": "number",
          "default": 8,
          "minimum": 2,
          "maximum": 40,
          "markdownDescription": "Base radius (in px) of graph nodes. Well-connected classes grow above this based on their degree."
        },
        "alat.textSize": {
          "type": "number",
          "default": 12,
          "minimum": 6,
          "maximum": 32,
          "markdownDescription": "Font size (in px) of node labels."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "publish:all": "bash scripts/publish.sh",
    "build": "node esbuild.js --production",
    "dev": "node esbuild.js --watch",
    "compile": "tsc --noEmit",
    "test": "node --require ts-node/register --test src/commands/__tests__/**/*.test.ts",
    "cucumber": "cucumber-js"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.63.0",
    "esbuild": "^0.28.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7"
  }
}
