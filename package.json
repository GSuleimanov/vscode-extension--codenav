{
  "name": "vscode-codenav-extension",
  "displayName": "Codenav — Code Dependency Graph & Visualization",
  "description": "Visualize your codebase as an interactive dependency graph. Explore call graphs, class diagrams, and code structure for any language.",
  "keywords": [
    "dependency graph",
    "code visualization",
    "diagram",
    "call graph",
    "code map",
    "uml",
    "class diagram",
    "code navigation",
    "architecture",
    "graph",
    "visualization",
    "code analysis"
  ],
  "version": "0.1.1",
  "publisher": "gsuleimanov",
  "license": "Apache-2.0",
  "icon": "images/codenav-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/GSuleimanov/vscode-extension--codenav.git"
  },
  "bugs": {
    "url": "https://github.com/GSuleimanov/vscode-extension--codenav/issues"
  },
  "homepage": "https://github.com/GSuleimanov/vscode-extension--codenav#readme",
  "engines": {
    "vscode": "^1.64.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codenav.openGraph",
        "title": "Open Project Graph",
        "category": "Codenav",
        "icon": "$(circuit-board)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "publish:all": "bash scripts/publish.sh",
    "build": "node esbuild.js --production",
    "dev": "node esbuild.js --watch",
    "compile": "tsc --noEmit",
    "test": "node --require ts-node/register --test src/commands/__tests__/**/*.test.ts",
    "cucumber": "cucumber-js"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.63.0",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7"
  }
}
